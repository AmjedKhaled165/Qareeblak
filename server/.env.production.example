# ========================================
# BACKEND + FRONTEND — Coolify Production Environment Variables
# Copy/paste these directly into Coolify → Service → Environment Variables
# ========================================

# ════════════════════════════════════════
# BACKEND (Express API) — api.qareeblak.com
# ════════════════════════════════════════

NODE_ENV=production
PORT=5000

# Neon.tech PostgreSQL (Pooled — for app runtime)
DATABASE_URL=postgresql://qareeblak_owner:npg_u24mYOGCwNjR@ep-purple-tooth-agcvtnrx-pooler.c-2.eu-central-1.aws.neon.tech/qareeblak?sslmode=require

# JWT — Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_64_CHAR_RANDOM_STRING

# CORS
CORS_ORIGINS=https://qareeblak.com,https://www.qareeblak.com
ALLOWED_ORIGINS=wss://api.qareeblak.com,https://api.qareeblak.com

# Cloudinary Image Storage
CLOUDINARY_CLOUD_NAME=dx7oiacwo
CLOUDINARY_API_KEY=966979598695962
CLOUDINARY_API_SECRET=q2pMl5TnyZAClTGHKGj0Fo5WFzw

# Redis (Coolify internal Docker network — use service name "redis")
REDIS_URL=redis://redis:6379

# WhatsApp Evolution API (Coolify internal Docker network)
EVOLUTION_API_URL=http://evolution-api:8080
# Generate a strong key: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
EVOLUTION_API_KEY=CHANGE_THIS_TO_STRONG_RANDOM_KEY
EVOLUTION_INSTANCE=whatsappbot

# Sentry (optional — get from https://sentry.io/settings/projects/)
SENTRY_DSN=

# ════════════════════════════════════════
# FRONTEND (Next.js) — qareeblak.com
# ════════════════════════════════════════

# Build Args (baked into the JS bundle — visible to browser)
NEXT_PUBLIC_API_URL=https://api.qareeblak.com
NEXT_PUBLIC_SOCKET_URL=https://api.qareeblak.com

# Server-side only (NOT exposed to browser — for Next.js rewrites)
INTERNAL_API_URL=http://qareeblak-api:5000
AUTH_SECRET=CHANGE_THIS_TO_STRONG_SECRET

# ════════════════════════════════════════
# EVOLUTION API (WhatsApp) — wa.qareeblak.com
# Set these in Coolify when creating the Evolution API Docker Compose service
# ════════════════════════════════════════

SERVER_URL=https://wa.qareeblak.com
AUTHENTICATION_TYPE=apikey
# Must match EVOLUTION_API_KEY above exactly
AUTHENTICATION_API_KEY=CHANGE_THIS_TO_SAME_KEY_AS_ABOVE
DATABASE_ENABLED=false
CACHE_REDIS_ENABLED=false
LOG_LEVEL=ERROR
DEL_INSTANCE=false
