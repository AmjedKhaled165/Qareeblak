# ========================================
# FRONTEND (Next.js) - Production Environment Variables
# Copy this to .env.production.local and fill in your values
# These MUST be set BEFORE running `next build`
# ========================================

# Your production backend API URL (REQUIRED)
NEXT_PUBLIC_API_URL=https://api.qareeblak.com

# Socket URL (defaults to API URL if not set in code)
NEXT_PUBLIC_SOCKET_URL=https://api.qareeblak.com

# Database (if Next.js server-side needs it)
DATABASE_URL=postgresql://Qareeblak:Q@r33bL@k_StR0ng_!26@qareeblak-db-server.postgres.database.azure.com:5432/postgres?sslmode=require

# Auth
AUTH_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING
JWT_SECRET=CHANGE_THIS_TO_A_SECURE_RANDOM_STRING

# Mock API - MUST be false in production
NEXT_PUBLIC_USE_MOCK_API=false
